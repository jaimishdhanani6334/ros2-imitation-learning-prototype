<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  
    <link name="arm_base_link">
        <visual>
            <origin xyz="0 0 0.01" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 0.1 0.02"/>
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>

            <geometry>
                <box size="0.1 0.1 0.02"/>
            </geometry>
        </collision>
        <inertial>

            <origin xyz="0 0 0" rpy="0 0 0"/>

            <mass value="0.5"/>

            <inertia
                ixx="0.001"
                ixy="0.0"
                ixz="0.0"
                iyy="0.001"
                iyz="0.0"
                izz="0.001"/>
        </inertial>       
    </link>
    
    <link name="forearm_link">
        <visual>
            
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.02" length="0.3"/>
            </geometry>
            <material name="yellow"/>
        </visual>
        <collision>

            <origin xyz="0 0 0.15"
                    rpy="0 0 0"/>

            <geometry>
                <cylinder radius="0.02" length="0.3" />
            </geometry>

        </collision>

        
        <inertial>

            <origin xyz="0 0 0.15"
                    rpy="0 0 0"/>

            <mass value="0.3"/>

            <inertia
                ixx="0.001"
                ixy="0.0"
                ixz="0.0"
                iyy="0.001"
                iyz="0.0"
                izz="0.001"/>
        </inertial>
    </link>

    <link name="left_finger_link">

        <visual>
            <origin xyz="0.04 0 0"
                    rpy="0 0 0"/>

            <geometry>
                <box size="0.08 0.01 0.02"/>
            </geometry>

            <material name="gray"/>
        </visual>

        <collision>
            <origin xyz="0.04 0.03 0"
                    rpy="0 0 0"/>

            <geometry>
                <box size="0.08 0.02 0.03"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.04 0.03 0"
                    rpy="0 0 0"/>

            <mass value="0.05"/>

            <inertia
                ixx="0.0001"
                ixy="0"
                ixz="0"
                iyy="0.0001"
                iyz="0"
                izz="0.0001"/>
        </inertial>

    </link>

    <link name="right_finger_link">

        <visual>
            <origin xyz="0.04 0 0"
                    rpy="0 0 0"/>

            <geometry>
                <box size="0.08 0.01 0.02"/>
            </geometry>

            <material name="gray"/>
        </visual>

        <collision>
            <origin xyz="0.04 -0.03 0"
                    rpy="0 0 0"/>

            <geometry>
                <box size="0.08 0.02 0.03"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.04 -0.03 0"
                    rpy="0 0 0"/>

            <mass value="0.05"/>

            <inertia
                ixx="0.0001"
                ixy="0"
                ixz="0"
                iyy="0.0001"
                iyz="0"
                izz="0.0001"/>
        </inertial>

    </link>

    
    <link name="hand_link">
        <visual>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.02" length="0.3"/>
            </geometry>
            <material name="orange"/>
        </visual>
       
        <collision>

            <origin xyz="0 0 0.15"
                    rpy="0 0 0"/>

            <geometry>
                <cylinder radius="0.02" length="0.3"/>
            </geometry>

        </collision>

        
        <inertial>

            <origin xyz="0 0 0.15"
                    rpy="0 0 0"/>

            <mass value="0.3"/>

            <inertia
                ixx="0.001"
                ixy="0.0"
                ixz="0.0"
                iyy="0.001"
                iyz="0.0"
                izz="0.001"/>
        </inertial>
    </link>

    
    <joint name="base_to_forearm_joint" type="revolute">
        <parent link="arm_base_link"/>
        <child link="forearm_link"/>

    
        <origin xyz="0 0 0.02" rpy="0 0 0"/>

        <axis xyz="0 1 0"/>

        <limit lower="0" upper="1.57"
               effort="10" velocity="1"/>
        <dynamics
            damping="3.0"
            friction="0.5"/>
    </joint>
    
    <joint name="forearm_to_hand_joint" type="revolute">
        <parent link="forearm_link"/>
        <child link="hand_link"/>

        
        <origin xyz="0 0 0.3" rpy="0 0 0"/>

        <axis xyz="0 1 0"/>

        <limit lower="0" upper="1.57"
               effort="10" velocity="1"/>
        <dynamics
            damping="3.0"
            friction="0.5"/>
    </joint>

    <joint name="left_finger_joint"
           type="revolute">

        <parent link="hand_link"/>

        <child link="left_finger_link"/>

        <origin xyz="0 0.025 0.3"
                rpy="0 0 0"/>

        <axis xyz="0 0 1"/>

        <limit
            lower="0"
            upper="0.5"
            effort="10"
            velocity="1"/>

    </joint>

    <joint name="right_finger_joint"
           type="revolute">

        <parent link="hand_link"/>

        <child link="right_finger_link"/>

        <origin xyz="0 -0.025 0.3"
                rpy="0 0 0"/>

        <axis xyz="0 0 -1"/>

        <limit
            lower="0"
            upper="0.5"
            effort="10"
            velocity="1"/>

    </joint>    


</robot>